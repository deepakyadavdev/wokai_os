{
  "name": "wokai",
  "version": "0.1.0",
  "private": true,
  "description": "WokAI - The AI that helps you finish work before it's too late.",
  "scripts": {
    "dev": "next dev",
    "build": "node --max-old-space-size=8192 node_modules/next/dist/bin/next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "omp": "omp",
    "omp:plan": "omp --plan",
    "omp:resume": "omp --resume",
    "verify": "npm run typecheck && npm run lint && npm run build"
  },
  "dependencies": {
    "@google/generative-ai": "0.24.1",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cors": "^2.8.6",
    "date-fns": "4.4.0",
    "express": "^5.2.1",
    "firebase": "12.15.0",
    "firebase-admin": "14.0.0",
    "framer-motion": "12.41.0",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "playwright": "^1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@oh-my-pi/pi-coding-agent": "16.1.16",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.1",
    "electron": "^42.5.0",
    "electron-packager": "^17.1.2",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
